    "test:watch": "vitest",
    "test:smoke": "playwright test",
    "test:smoke:0e03": "playwright test tests/smoke/phase-0e-03-smoke.spec.ts"
  },
  "dependencies": {
    "@lucide/vue": "^1.17.0",
    "pinia": "^3.0.2",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@playwright/test": "1.60.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.28.0",
    "eslint-plugin-vue": "^10.1.0",
    "jsdom": "^26.1.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.34.0",
    "vite": "^6.3.5",
    "vitest": "^3.2.1",
    "vue-tsc": "^2.2.8"
  }
}
