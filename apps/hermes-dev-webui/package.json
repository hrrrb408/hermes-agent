{
  "name": "@hermes/dev-webui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Hermes Dev WebUI - Theme Lab and visual workbench",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint .",
